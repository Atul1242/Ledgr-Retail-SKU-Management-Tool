# ════════════════════════════════════════════════════════════════════
# Ledgr — Environment Configuration  (copy to .env to override defaults)
# ════════════════════════════════════════════════════════════════════
# Every variable below has a working default in docker-compose.yml.
# `docker compose up` works without a .env file at all. Override only
# what you need (real secrets in prod, OpenRouter key for live chatbot).
# ════════════════════════════════════════════════════════════════════

# ── Postgres (used only by docker-compose.yml; ignored if running
#    locally with the SQLite fallback). ─────────────────────────────
POSTGRES_DB=ledgr
POSTGRES_USER=ledgr
POSTGRES_PASSWORD=ledgr_local_dev

# ── Web port mapping on the host ──────────────────────────────────
WEB_PORT=5000

# ── Flask ─────────────────────────────────────────────────────────
# When FLASK_ENV=production, FLASK_SECRET_KEY MUST be a real random
# value or the app refuses to start (see app.py).
FLASK_SECRET_KEY=ledgr-local-dev-secret-change-in-prod
FLASK_ENV=development

# ── OpenRouter key for the AI chatbot (Ledgr falls back to a local
#    keyword answer engine if this is unset — chat still works). ──
OPENROUTER_KEY=

# ── Optional integrations (Phase 13) — leave blank to disable ────
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886
OWNER_WHATSAPP_TO=

MAIL_SERVER=
MAIL_PORT=587
MAIL_USE_TLS=true
MAIL_USERNAME=
MAIL_PASSWORD=
OWNER_EMAIL=

TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ── Demo accounts ────────────────────────────────────────────────
# Hides the demo-credentials block on the login page when set to 1.
HIDE_DEMO_CREDENTIALS=
